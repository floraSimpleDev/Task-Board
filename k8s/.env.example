# Copy to k8s/.env (gitignored) and fill in real values.
# manage.sh reads these to:
#   1. generate the postgres-credentials and backend-secrets Secrets
#   2. pass VITE_AUTH0_* build args when building the frontend image (Vite
#      embeds env vars at build time, so they must be known before npm run build)
# Nothing sensitive is ever committed to git.

# --- Postgres (cluster-internal only) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=taskboard

# --- Auth0: shared by frontend and backend ---
# Tenant domain only, no scheme. e.g. your-tenant.us.auth0.com
AUTH0_DOMAIN=your-tenant.us.auth0.com
# API identifier configured in the Auth0 dashboard.
AUTH0_AUDIENCE=https://task-board.local/api

# --- Auth0: frontend-only (baked into the Vite bundle at image-build time) ---
# Client ID of the Auth0 SPA Application.
AUTH0_CLIENT_ID=your-spa-client-id
# Where Auth0 redirects after login. MUST be allow-listed in the Auth0
# Application's "Allowed Callback URLs". For the K8s smoke test we'll
# port-forward the frontend to this URL.
AUTH0_REDIRECT_URI=http://localhost:8080/
