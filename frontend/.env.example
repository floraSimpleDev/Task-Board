# Vite exposes only variables prefixed with VITE_ to the client bundle.
# Copy this file to .env.local and fill in the values for local development.

# Backend API base URL (used by the frontend to talk to the API)
VITE_API_URL=http://localhost:3000

# Auth0 SPA application settings (from your Auth0 tenant → Applications)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id

# Auth0 API identifier (must match backend AUTH0_AUDIENCE)
VITE_AUTH0_AUDIENCE=https://your-task-audience

# Where Auth0 redirects after login; typically the running app origin
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/
