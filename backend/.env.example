# Copy this file to .env and fill in the values for local development.
# The .env file is gitignored; never commit real secrets.

# Runtime
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# PostgreSQL connection string
DATABASE_URL=

# Auth0 — used for JWKS-based JWT verification
# The issuer is https://<AUTH0_DOMAIN>/ (trailing slash matters)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173
